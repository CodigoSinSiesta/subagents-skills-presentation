import Slide02TheProblem from '../components/slides/Slide02TheProblem.svelte';
import Slide03WhatIsSubagent from '../components/slides/Slide03WhatIsSubagent.svelte';
import Slide04OrchestrationPatterns from '../components/slides/Slide04OrchestrationPatterns.svelte';
import Slide05OrchestrationBenefits from '../components/slides/Slide05OrchestrationBenefits.svelte';
import Slide06SkillsConcept from '../components/slides/Slide06SkillsConcept.svelte';
import Slide07SkillAnatomy from '../components/slides/Slide07SkillAnatomy.svelte';
import Slide08ReferenceSkills from '../components/slides/Slide08ReferenceSkills.svelte';
import Slide09SkillsPractice from '../components/slides/Slide09SkillsPractice.svelte';
import Slide10SubagentSkillsSynergy from '../components/slides/Slide10SubagentSkillsSynergy.svelte';
import Slide11ContextManagement from '../components/slides/Slide11ContextManagement.svelte';
import Slide12RealWorldPatterns from '../components/slides/Slide12RealWorldPatterns.svelte';
